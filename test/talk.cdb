					"nextId": "d002",
					"isEnd": false
				},
				{
					"id": "d002",
					"speaker": "player",
					"text": "",
					"emotion": 2,
					"isEnd": false,
					"choices": [
						{
							"text": "I need information.",
							"nextId": "d003"
						},
						{
							"text": "I'm looking for work.",
							"nextId": "d004"
						},
						{
							"text": "Just passing through. Farewell.",
							"nextId": "d005"
						}
					]
				},
				{
					"id": "d003",
					"speaker": "npc1",
					"text": "What kind of information do you seek?",
					"emotion": 4,
					"nextId": "d002",
					"isEnd": false
				},
				{
					"id": "d004",
					"speaker": "npc1",
					"text": "Indeed! We have a quest for you...",
					"emotion": "happy",
					"nextId": "d006",
					"isEnd": false
				},
				{
					"id": "d005",
					"speaker": "npc1",
					"text": "Safe travels, stranger!",
					"emotion": "normal",
					"isEnd": true
				},
				{
					"id": "d006",
					"speaker": "npc1",
					"text": "The goblins have been spotted near the old mine. Bring me 3 goblin ears as proof.",
					"emotion": "normal",
					"nextId": "d007",
					"isEnd": false
				},
				{
					"id": "d007",
					"speaker": "player",
					"text": "",
					"emotion": "normal",
					"isEnd": false,
					"choices": [
						{
							"text": "I'll do it!",
							"nextId": "d008"
						},
						{
							"text": "What's the reward?",
							"nextId": "d009"
						}
					]
				},
				{
					"id": "d008",
					"speaker": "npc1",
					"text": "Excellent! Return when you have the ears.",
					"emotion": "happy",
					"isEnd": true
				},
				{
					"id": "d009",
					"speaker": "npc1",
					"text": "I can offer you 100 gold coins.",
